generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Business {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes     Quote[]
  jobs       Job[]
  workers    Worker[]
  lineItems  LineItem[]
  clients    Client[]
  settings   Json?
}

model Quote {
  id             String   @id @default(cuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id])
  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id])
  clientName     String?
  clientEmail    String?
  clientPhone    String?
  address        String?
  squareFootage  Float    @default(0)
  ratePerSqFt    Float    @default(0.15)
  workerCount    Int      @default(1)
  status         String   @default("draft") // draft, sent, accepted, rejected
  notes          String?
  total          Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  quoteLineItems QuoteLineItem[]
  quoteAddons    QuoteAddon[]
  job            Job?
}

model LineItem {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  name        String
  description String?
  basePrice   Float    @default(0)
  hasSizeMod  Boolean  @default(false)   // e.g. "Bathroom" → Small/Med/Large
  sizeSmall   Float?
  sizeMedium  Float?
  sizeLarge   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QuoteLineItem {
  id        String   @id @default(cuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id])
  name      String
  price     Float
  size      String?  // Small, Medium, Large (if applicable)
  quantity  Int      @default(1)
}

model Client {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  name       String
  phone      String?
  email      String?
  address    String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  quotes Quote[]
  jobs   Job[]
}

model QuoteAddon {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id])
  name    String
  price   Float
}

model Job {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])
  quoteId       String?  @unique
  quote         Quote?   @relation(fields: [quoteId], references: [id])
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id])
  clientName    String
  clientPhone   String?
  clientEmail   String?
   address       String
   latitude      Float?    // auto-geocoded from address; geofence target for photo uploads
   longitude     Float?
   total         Float    @default(0)
   status        String   @default("pending") // pending, in_progress, completed, cancelled
   scheduledDate DateTime?
   notes         String?
   isRecurring           Boolean  @default(false)
  recurrencePattern     String?  // weekly, biweekly, fourWeekly, monthly
  recurrenceEndDate     DateTime?
  recurringTemplateId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sections        JobSection[]
  startWithTasks  StartWithTask[]
  assignments     JobAssignment[]
  childJobs       Job[]        @relation("RecurringJob")
  parentJob       Job?         @relation("RecurringJob", fields: [recurringTemplateId], references: [id])
}

model JobSection {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  name      String   // e.g. "Kitchen", "Bathroom 1F", "Break Room"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks JobTask[]
}

model JobTask {
  id            String   @id @default(cuid())
  sectionId     String
  section       JobSection @relation(fields: [sectionId], references: [id])
  description   String
  sortOrder     Int      @default(0)
  completed     Boolean  @default(false)
  requiredPhoto Boolean  @default(false)
  comment       String?
  completedBy   String?  // workerId
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  photos TaskPhoto[]
}

model TaskPhoto {
  id           String   @id @default(cuid())
  taskId       String
  task         JobTask  @relation(fields: [taskId], references: [id])
  url          String   // processed, stamped, compressed base64 data URL
  takenAt      DateTime @default(now())
  takenBy      String?  // workerId
  latitude     Float?   // worker's GPS at capture time
  longitude    Float?
  locationAccuracy Float? // GPS accuracy in meters
  photoTakenAt DateTime? // actual moment the photo was captured (client timestamp)
}

model StartWithTask {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id])
  description String
  sortOrder   Int      @default(0)
  completed   Boolean  @default(false)
  completedBy String?
  completedAt DateTime?
}

model Worker {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  firstName  String
  lastName   String
  email      String?
  phone      String?
  role       String   @default("worker") // worker, supervisor, admin
  status     String   @default("active") // active, inactive
  notes      String?

  // W-9 info
  w9Uploaded   Boolean  @default(false)
  w9FileName   String?
  w9FileUrl    String?
  w9ParsedName String?
  w9ParsedTin  String?
  w9ParsedAddress String?
  w9Reviewed   Boolean  @default(false)
  w9ReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments      JobAssignment[]
  availability     WorkerAvailability[]
  user             User?              @relation
  profileChanges ProfileChange[]
}

model JobAssignment {
  id           String   @id @default(cuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id])
  workerId     String
  worker       Worker   @relation(fields: [workerId], references: [id])
  scheduledDate DateTime?
  assignedAt   DateTime @default(now())
}

model WorkerAvailability {
  id        String   @id @default(cuid())
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0=Sun, 1=Mon ... 6=Sat
  startTime String   // HH:mm format
  endTime   String   // HH:mm format
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id               String   @id @default(cuid())
  email            String?  @unique
  passwordHash     String?
  role             String   @default("worker") // admin, worker
  workerId         String?  @unique
  worker           Worker?  @relation(fields: [workerId], references: [id])
  mustResetPassword Boolean  @default(false)
  identifierToken  String?  @unique
  displayName      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions        Session[]
  notifications   Notification[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ProfileChange {
  id          String    @id @default(cuid())
  workerId    String
  worker      Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  field       String
  oldValue    String?
  newValue    String
  status      String    @default("pending") // pending, approved, rejected
  requestedBy String
  reviewedBy  String?
  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
