{% set localeData = en if locale == 'en' else es %}
{% set pageData = localeData.pages[pageKey] if pageKey else {} %}
<!DOCTYPE html>
<html lang="{{ localeData.lang }}">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>{{ pageData.title or 'Maloon Cleaning Service' }}</title>
    {% if pageData.description %}
    <meta name="description" content="{{ pageData.description }}"/>
    {% endif %}
    
    {%- if pageKey == 'index' %}
    <link href="/css/theme.css" rel="stylesheet" type="text/css">
    {% endif -%}
    <link rel="stylesheet" href="/assets/css/main.css"/>
    {%- if pageKey == 'index' %}
    <link rel="stylesheet" href="/assets/css/hero-new.css"/>
    {% endif -%}
    <link rel="icon" href="/Maloon Service Logo-Favicon.svg" type="image/svg+xml"/>
    <meta name="robots" content="index, follow"/>
    
    {% if pageData.ogTitle %}
    <meta property="og:title" content="{{ pageData.ogTitle }}"/>
    {% endif %}
    {% if pageData.ogDescription %}
    <meta property="og:description" content="{{ pageData.ogDescription }}"/>
    {% endif %}
    <meta property="og:type" content="website"/>
    
    {# Hreflang tags for bilingual SEO #}
    {% if locale == 'en' %}
    <link rel="alternate" hreflang="en" href="https://maloonservices.com/{{ pageKey }}.html"/>
    <link rel="alternate" hreflang="es" href="https://maloonservices.com/es/{{ pageKey }}.html"/>
    {% else %}
    <link rel="alternate" hreflang="en" href="https://maloonservices.com/{{ pageKey }}.html"/>
    <link rel="alternate" hreflang="es" href="https://maloonservices.com/es/{{ pageKey }}.html"/>
    {% endif %}
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>
    
    {% if pageKey == 'index' %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "{{ localeData.brand.name }}",
      "image": "https://maloonservices.com{{ localeData.brand.logo }}",
      "email": "{{ localeData.contact.email }}",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "123 Cleaning Way",
        "addressLocality": "Columbus",
        "addressRegion": "OH",
        "postalCode": "43215",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 40.014985,
        "longitude": -83.017259
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "08:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "08:00",
          "closes": "18:00"
        }
      ],
      "url": "https://maloonservices.com",
      "sameAs": [
        "https://www.facebook.com/",
        "https://twitter.com/",
        "https://www.instagram.com/",
        "https://www.linkedin.com/"
      ],
      "description": "Professional cleaning services for both commercial and residential clients in Columbus, OH and Central Ohio. Eco-friendly, reliable, and detail-focused."
    }
    </script>
    {% endif %}
</head>
<body id="main-content">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    {%- if not hideStickyBar %}
    {# Sticky quote bar #}
    {% include "sticky-quote-bar.njk" %}
    {% endif -%}
    
    {# Navigation #}
    {% include "navbar.njk" %}
    
    {%- if not hideSidebar %}
    {# Main layout wrapper with sidebar #}
    <div class="sidebar-wrapper">
        <main class="main-content">
            {{ content | safe }}
        </main>
        {# Sidebar (right side) - populated by JS #}
    </div>
    {%- else %}
    {# Main layout without sidebar #}
    <main class="main-content">
        {{ content | safe }}
    </main>
    {% endif -%}
    
    {# Footer #}
    {% include "footer.njk" %}
    
    <script src="/assets/js/main.js"></script>
    {%- if pageKey == 'index' %}
    <script src="/assets/js/hero-new.js"></script>
    {% endif -%}
</body>
</html>
