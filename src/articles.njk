---
layout: base.njk
pageKey: articles
locale: en
permalink: /articles.html
---

{% set localeData = en %}
{% set pageData = localeData.pages.articles %}

{# Hero Section #}
<section class="articles-hero">
    <div class="container">
        <h1>Cleaning Articles & Expert Tips</h1>
        <p>Helpful guides and insights from our cleaning professionals</p>
    </div>
</section>

{# Articles Grid #}
<section class="articles-grid section-white section-spacing">
    <div class="container">
        <div class="grid-3">
            {% for article in localeData.articles %}
            {% set anchorId = article.link | replace('articles.html#', '') %}
            <article id="{{ anchorId }}" class="article-card reveal">
                <div class="article-icon">📝</div>
                <h3>{{ article.title }}</h3>
                <p class="article-meta">{{ article.date }} • 5 min read</p>
                <p>{{ article.excerpt }}</p>
            </article>
            {% endfor %}
        </div>
    </div>
</section>

{# CTA #}
<section class="articles-cta section-green section-spacing reveal">
    <div class="container">
        <div class="section-header-center">
            <h2 style="color: var(--white);">Ready for Professional Cleaning?</h2>
            <p style="color: rgba(255,255,255,0.9);">Get a free quote for your business or home today</p>
        </div>
        <div class="cta-buttons">
            <a href="{{ localeData.contact.whatsapp }}" class="btn-cta-sparkle">
                <i class="fab fa-whatsapp"></i>
                Message us on WhatsApp
            </a>
        </div>
    </div>
</section>
